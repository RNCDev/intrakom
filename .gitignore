# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/

# ── Build outputs ─────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.spec.bak

# ── PyInstaller runtime temp ──────────────────────────────────────────────────
_MEIPASS*/

# ── Test / coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

