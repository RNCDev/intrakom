cert.key
cert.conf
*.pem
*.key

# ── Machine-specific runtime files ───────────────────────────────────────────
config.ini
*.log
*.log.*
assets/

# ── macOS noise ───────────────────────────────────────────────────────────────
.DS_Store
._*

# ── Windows noise ────────────────────────────────────────────────────────────
Thumbs.db
desktop.ini

# ── Claude / tooling ─────────────────────────────────────────────────────────
.claude/scheduled_tasks.lock
.worktrees/
.superpowers/
docs/superpowers/
*.local.md
